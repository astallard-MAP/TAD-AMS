rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /leads/{leadId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    
    // Communication Interaction Records (IMMUTABLE)
    match /communications/{msgId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid || request.auth.uid == 'Djh7uHK2yZYHC4Ta4xhbguaCJVl1');
      allow update, delete: if false; // STRICT IMMUTABILITY
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /marketUpdates/{docId} {
      allow read: if true;
    }

    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == 'Djh7uHK2yZYHC4Ta4xhbguaCJVl1';
    }
  }
}
